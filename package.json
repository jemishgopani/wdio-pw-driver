{
  "name": "wdio-pw-driver",
  "version": "0.1.0-alpha.0",
  "description": "WebdriverIO driver powered by Playwright internals — drives Chromium / Firefox / WebKit in-process, no chromedriver, no HTTP. Same WDIO API.",
  "type": "module",
  "author": "jemishgopani <jemishgopani2@gmail.com>",
  "homepage": "https://jemishgopani.github.io/wdio-pw-driver/",
  "repository": {
    "type": "git",
    "url": "https://github.com/jemishgopani/wdio-pw-driver.git"
  },
  "bugs": {
    "url": "https://github.com/jemishgopani/wdio-pw-driver/issues"
  },
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "bin": {
    "wdioPW": "./bin/wdio-pw.js"
  },
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "files": [
    "build",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "wdio run tests/e2e/wdio.conf.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=18.20.0"
  },
  "license": "MIT",
  "keywords": [
    "webdriverio",
    "wdio",
    "wdio-driver",
    "wdio-service",
    "playwright",
    "playwright-core",
    "chromium",
    "firefox",
    "webkit",
    "browser-automation",
    "automation",
    "e2e",
    "testing",
    "test-runner"
  ],
  "dependencies": {
    "@wdio/logger": "^9.0.0",
    "@wdio/protocols": "^9.0.0",
    "@wdio/utils": "^9.0.0"
  },
  "peerDependencies": {
    "@wdio/types": ">=9.0.0",
    "playwright-core": ">=1.40.0",
    "webdriverio": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "webdriverio": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.27.1",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "eslint": "^9.0.0",
    "expect-webdriverio": "^5.6.5",
    "playwright-core": "^1.40.0",
    "rimraf": "^6.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "webdriverio": "^9.0.0"
  }
}
