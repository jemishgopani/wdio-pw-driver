{
  "name": "wdio-pw-driver-example-saucedemo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Reference example: WebdriverIO + wdio-pw-driver against the SauceDemo public site.",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:headed": "HEADLESS=false wdio run wdio.conf.ts",
    "test:firefox": "wdio run wdio.firefox.conf.ts",
    "test:webkit": "wdio run wdio.webkit.conf.ts",
    "test:all-engines": "pnpm test && pnpm test:firefox && pnpm test:webkit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "expect-webdriverio": "^5.0.0",
    "wdio-pw-driver": "file:../..",
    "playwright-core": "^1.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
