{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "@wdio/globals/types",
      "@wdio/mocha-framework",
      "expect-webdriverio",
      "wdio-pw-driver",
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "wdio.conf.ts",
    "wdio.shared.ts",
    "wdio.firefox.conf.ts",
    "wdio.webkit.conf.ts",
    "test/**/*",
    "globals.d.ts"
  ]
}
